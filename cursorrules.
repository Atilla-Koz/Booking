## Zod Shared Schemas (packages/shared)

```ts
// All schemas must be defined here and reused in both apps

export const BookingRequestSchema = z.object({
  userId: z.string().uuid(),
  date: z.string().regex(/^\d{4}-\d{2}-\d{2}$/),
  timeSlot: z.string(),
})

export const AvailableSessionSchema = z.object({
  timeSlot: z.string(),
  startTime: z.string(),
  durationMinutes: z.number(),
  available: z.boolean(),
})

export type BookingRequest = z.infer<typeof BookingRequestSchema>
export type AvailableSession = z.infer<typeof AvailableSessionSchema>
```

